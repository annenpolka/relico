{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "warframe-fissure-notifier",
  "version": "0.1.0",
  "identifier": "com.annenpolka.warframe-fissure-notifier",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "FISSURE OPS — PC WORLDSTATE",
        "width": 960,
        "height": 620,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
