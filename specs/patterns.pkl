/// パターン語彙のスキーマ定義。
/// dspec方式の「対応するパターンだけを書ける狭い語彙」。全域表現は意図的に捨てる。
///
/// ルール内はAND、複数ルールは用途ごとにORする。
/// 一覧表示はenabled=trueのルール、通知はnotify=trueのルールを使い、両者は独立する。
/// enabled=false, notify=trueの非表示ルールも通知判定へ参加する。
///
/// Rustスニペット(ruleOverride / fissureOverride)内で使える束縛:
///   rule: WatchRule(mut) / s: FilterSettings(mut) / f: Fissure(mut) / now: DateTime<Utc>
module patterns

abstract class Clause {
  /// 条項id。例: FLT-001, E2E-001
  id: String(matches(Regex(#"[A-Z][A-Z0-9]{2}-\d{3}"#)))

  /// 生成器が分岐するパターン名(サブクラスが固定値を与える)
  pattern: String

  /// 自然言語での条項内容(SPEC.mdにそのまま出る)
  desc: String

  /// 保証ラベル。proven / model-checked は存在しない(勾配を平らに見せない)
  label: "property-tested" | "example-tested" | "manual"
}

/// rule述語 ∧ fissure述語 → そのルールは合致しない(ルール単位の棄却)
class RuleRejectWhen extends Clause {
  pattern = "rule_reject_when"
  label = "property-tested"
  ruleOverride: String = ""
  fissureOverride: String = ""
}

/// storm条件以外を全対象に固定し、StormMode三値の真理値表を検証する。
class StormTruthTable extends Clause {
  pattern = "storm_truth_table"
  label = "property-tested"
}

/// VOID嵐のnodeでAPIが返す基底惑星名と、UIのProxima名の対応を検証する。
class ProximaNodeAliases extends Clause {
  pattern = "proxima_node_aliases"
  label = "property-tested"
}

/// ルールの軸が空のとき、その軸を理由にそのルールが棄却しない。
/// 検証形: rule_matches(軸=[], f) == rule_matches(軸=[fに合致する値], f)
class RulePassWhenEmpty extends Clause {
  pattern = "rule_pass_when_empty"
  label = "property-tested"
  /// WatchRuleのフィールド名
  axisField: "tiers" | "mission_types" | "planets" | "factions"
  /// fに合致する値を作るRust式
  matchExpr: String
}

/// 通知候補用filterの設定全体の述語 ∧ fissure述語 → 全体として合致しない
/// (ルール構成に依らない棄却)
class SettingsRejectWhen extends Clause {
  pattern = "settings_reject_when"
  label = "property-tested"
  fissureOverride: String = ""
}

/// 通知候補用filterで、ルール1つの設定では、
/// 全体合致 = (残り時間OK ∧ enabled ∧ そのルールの条件合致)
class SingleRuleEmbedding extends Clause {
  pattern = "single_rule_embedding"
  label = "property-tested"
}

/// enabled=trueのルールを追加しても、それまでfilter合致していた亀裂は合致し続ける
/// (ルールORの単調性)
class RuleAdditivity extends Clause {
  pattern = "rule_additivity"
  label = "property-tested"
}

/// 通知候補用filterの全体合致は残り時間条件と、enabled=trueのルールだけをORした結果に等しい。
/// 全ルール無効またはルールなしなら合致しない。
class EnabledRulesOr extends Clause {
  pattern = "enabled_rules_or"
  label = "property-tested"
}

/// runtime通知範囲を表す射影は、notify=trueのルールを表示選択(enabled)と独立に
/// 元の順序で残し、共通の残り時間条件を保持する。notify=false draftの変更は射影を変えない。
class NotificationProjection extends Clause {
  pattern = "notification_projection"
  label = "property-tested"
}

/// 同一idは任意の操作列で高々1回しか通知されない
class AtMostOnce extends Clause {
  pattern = "at_most_once"
  label = "property-tested"
}

/// pruneは生存中idの通知済み状態を保持し、期限切れidを除去する
class PrunePreservesLive extends Clause {
  pattern = "prune_preserves_live"
  label = "property-tested"
}

/// 同じ亀裂へ複数のVIEWルールまたは通知ルールが合致しても、各候補集合では亀裂id単位の1件であり、
/// dedupにより高々1回しか通知されない。
class OverlappingRulesAtMostOnce extends Clause {
  pattern = "overlapping_rules_at_most_once"
  label = "property-tested"
}

/// 惑星抽出が全入力でパニックせず、整形式 "Node (Planet)" でPlanetを返す
class ParseTotal extends Clause {
  pattern = "parse_total"
  label = "property-tested"
}

/// バックオフの返す遅延が常に[minSecs, maxSecs]に収まる
class Bounded extends Clause {
  pattern = "bounded"
  label = "property-tested"
  minSecs: Int
  maxSecs: Int
}

/// シードモード(起動直後の初回ポーリング)では、合致亀裂を通知済みとして
/// 記録するだけで、通知対象には1件も選ばれない
class SeedSilent extends Clause {
  pattern = "seed_silent"
  label = "property-tested"
}

/// 初回起動または通知ルール射影の変更時だけ通知範囲変更と判定し、
/// 変更時点の現存対象はsilent seedする。表示選択だけの変更では再seedしない。
class NotificationScopeChange extends Clause {
  pattern = "notification_scope_change"
  label = "property-tested"
}

/// 日次通知ミュート区間はローカル時刻の分単位で[start, end)として評価する。
/// start>endは日跨ぎ、start==endは安全側の空区間とし、全1440分で真理値を検査する。
class DailyMuteWindow extends Clause {
  pattern = "daily_mute_window"
  label = "property-tested"
}

/// 起動時seedまたは通知ミュート中の候補は通知済みとしてmarkするが配送対象へ返さず、
/// 通常配送へ戻したとき既存idを滞留通知せず、その後の新規idだけを返す。
class MutedDelivery extends Clause {
  pattern = "muted_delivery"
  label = "property-tested"
}

/// browse.wf仲裁scheduleは空nodeを許さず、隣接slotが厳密に3600秒間隔で昇順になる。
/// lookupは先頭以上・末尾slot終了未満だけを定義域とし、範囲外を循環・補間しない。
class ArbitrationSchedule extends Clause {
  pattern = "arbitration_schedule"
  label = "property-tested"
  scenario: "validation" | "lookup"
}

/// 時限コンテンツsourceは成功したsliceだけを置換し、失敗sliceはlast-known-goodを保持する。
/// 他sourceのcard・healthを変更しないことを操作組合せで検査する。
class TimedSourceIsolation extends Clause {
  pattern = "timed_source_isolation"
  label = "property-tested"
}

/// browse.wf Oracleのbounty-cycleはJSON/HTTP成功だけでは採用せず、
/// expiryが有効な未来時刻である場合だけfreshとして扱う。
class BountyFreshness extends Clause {
  pattern = "bounty_freshness"
  label = "property-tested"
}

/// 表示リストはフィルタ合致亀裂のみを含み(健全性)、
/// 合致する亀裂を1件も取りこぼさない(完全性)
class FilteredView extends Clause {
  pattern = "filtered_view"
  label = "property-tested"
}

/// 通知候補はnotify=trueのルールのORに合致する亀裂のみ(健全性)・取りこぼしなし(完全性)。
/// enabled=falseの非表示ルールも通知へ参加し、一覧表示とは独立する。
class NotifyCandidates extends Clause {
  pattern = "notify_candidates"
  label = "property-tested"
}

/// ファジーマッチの健全性: マッチ成立時、クエリ文字は候補文字列に
/// 順序保存の部分列として(大文字小文字無視で)現れる
class FuzzySubsequence extends Clause {
  pattern = "fuzzy_subsequence"
  label = "property-tested"
}

/// 空クエリは候補全件を返す(完全性)
class FuzzyEmptyQuery extends Clause {
  pattern = "fuzzy_empty_query"
  label = "property-tested"
}

/// クエリと完全一致する候補(label/alias)が存在すれば、先頭候補は完全一致である
class FuzzyExactFirst extends Clause {
  pattern = "fuzzy_exact_first"
  label = "property-tested"
}

/// 同一クエリ・同一候補集合に対する結果順序は決定的
class FuzzyDeterministic extends Clause {
  pattern = "fuzzy_deterministic"
  label = "property-tested"
}

/// パレット操作列をどう並べても、適用後の全ルールがドメイン互換表に関して
/// 充足可能(ルール内で両立しない選択は新しい方を残して上書き解決)
class SatisfiableAfterOps extends Clause {
  pattern = "satisfiable_after_ops"
  label = "property-tested"
}

/// edit focus・一覧表示選択(enabled)・通知参加(notify)を独立に扱う。
/// enabled/notify変更は条件とedit indexを変えず、非表示ルールの条件編集も表示選択を変えない。
class EditorActivationIndependent extends Clause {
  pattern = "editor_activation_independent"
  label = "property-tested"
}

/// NEW RULEは既存ルールを変えず、表示OFF・通知OFFのdraftを末尾へ追加してedit対象にする。
class NewRuleDisabled extends Clause {
  pattern = "new_rule_disabled"
  label = "property-tested"
}

/// 表示選択が0本でfilter候補を適用すると、安全な新しいVIEWルールを作る。
/// 明示的な空draftがedit対象ならそれを再利用し、後続候補は同じルールへ連続適用する。
class UnselectedApplyCreatesRule extends Clause {
  pattern = "unselected_apply_creates_rule"
  label = "property-tested"
}

/// クリア操作は1回でルール構成を既定(全対象ルール1本)に戻す
class ClearResets extends Clause {
  pattern = "clear_resets"
  label = "property-tested"
}

/// 実行時カタログは各ルールをrule:{index}候補(label=ルール名、未設定ならR{n})として含み、
/// 適用は対象ルールのenabledだけを反転して条件・順序・edit indexを変えない(再適用で往復)。
/// 全ルール解除は全enabledだけをfalseにし、ルール本体・notify・edit indexを保持する。
class RuleToggleCandidates extends Clause {
  pattern = "rule_toggle_candidates"
  label = "property-tested"
}

/// 旧WatchRule JSONのincludeStorms:booleanを新StormModeへ無損失移行する。
class LegacyStormConfig extends Clause {
  pattern = "legacy_storm_config"
  label = "property-tested"
}

/// enabledを持たない旧WatchRule JSONは表示選択として読み込み、明示falseはround-tripで保持する。
class LegacyRuleEnabled extends Clause {
  pattern = "legacy_rule_enabled"
  label = "example-tested"
}

/// ルール名は省略可能な表示用メタデータ。欠落した旧JSONは名前なしで読み込み、
/// 設定した名前はserialize/deserializeを往復しても保持される。
class RuleNameConfig extends Clause {
  pattern = "rule_name_config"
  label = "example-tested"
}

/// ルールのnotifyは通知参加フラグ。欠落した旧JSONは旧enabled値を引き継ぎ、
/// 明示したtrue/falseはenabledと独立にround-tripで保持される。
class RuleNotifyConfig extends Clause {
  pattern = "rule_notify_config"
  label = "example-tested"
}

/// AppConfigへ後方互換に追加するlocaleと通知ミュート設定を具体例で検査する。
class AppConfigCompat extends Clause {
  pattern = "app_config_compat"
  label = "example-tested"
}

/// 時限コンテンツ監視ルール(contentRules)の合致意味論。空軸=全対象。
/// キーワード条件とレベル条件は同一stage上の連言で、enemy levelを持たないstageへ
/// レベル条件は合致しない(レベルを捏造しない)。
class ContentRuleMatch extends Clause {
  pattern = "content_rule_match"
  label = "property-tested"
}

/// コンテンツ通知の選択: seed中・ミュート中は通知済みmarkのみで配送せず、
/// 同一card idは高々1回だけ配送され、配送対象は常に合致集合の部分集合。
class ContentNotifyOnce extends Clause {
  pattern = "content_notify_once"
  label = "property-tested"
}

/// コンテンツ通知範囲のprojection: notify=trueルールだけを元の順序で正規化キーワード
/// と共に保持し、名前・notify=falseルールの変更では変わらない。変更時だけ再seedする。
class ContentScopeChange extends Clause {
  pattern = "content_scope_change"
  label = "property-tested"
}

/// コンテンツ監視ルールのキーワードをパレットのミッションalias語彙で正準化する。
/// 未知キーワードはrawのまま使う。
class ContentKeywordCanonical extends Clause {
  pattern = "content_keyword_canonical"
  label = "example-tested"
}

/// contentRulesの後方互換設定読込とround-tripを具体例で検査する。
class ContentRulesConfig extends Clause {
  pattern = "content_rules_config"
  label = "example-tested"
}

/// タブ別コンテンツピッカー: 亀裂以外のコンテンツタブでパレットが出す候補カタログと、
/// contentRulesへの適用意味論。編集先はタブ専用(kinds非空かつタブkind群と交差)ルールの末尾で、
/// kinds未指定の全タブ共通ルールは条件編集の対象にしない。
class ContentPalette extends Clause {
  pattern = "content_palette"
  label = "property-tested"
  scenario: "picker_catalog" | "picker_apply" | "picker_target"
}

/// 時限コンテンツの外部payloadを固定fixtureで正規化し、source・詳細field・wire shapeを検査する。
/// network到達性や第三者scheduleの将来正確性はManualへ残す。
class TimedContentFixture extends Clause {
  pattern = "timed_content_fixture"
  label = "example-tested"
  scenario: "wire_shape" | "arbitration_join" | "oracle_bounties" | "circuit" | "rich_details" | "area_sources"
}

/// 通知テストの結果表示・payload・raw dev時の案内を、固定した具体例で検証する。
/// 外部OSへの実配送や人間による知覚はManualへ残す。
class NotificationExample extends Clause {
  pattern = "notification_example"
  label = "example-tested"
  scenario: "outcomes" | "desktop_payload" | "desktop_unavailable" | "discord_receipt" | "localized_backend" | "content_payload"
}

/// リポジトリ内の静的成果物(設定ファイル・アイコン・配線)を生成テストで検査する。
/// ビルド成果物や実行時挙動は対象にしない(それらはE2E/manualの領分)。
class StaticCheck extends Clause {
  pattern = "static_check"
  label = "example-tested"
  scenario: "bundle_identity" | "tray_template_icon" | "autostart_bundle_icon" | "dependency_free_i18n" | "windows_distribution"
}

/// 人間が一度目視承認したアセットをsha256で固定する。
/// ハッシュ不一致 = 内容が変わったので目視で再承認し、ここのsha256を更新する。
/// 「毎リリース目視」を「一回承認 + 機械の鮮度監視」へ置き換えるためのパターン。
class ApprovedAsset extends Clause {
  pattern = "approved_asset"
  label = "example-tested"
  /// src-tauri/ (CARGO_MANIFEST_DIR) からの相対パス
  path: String
  sha256: String(matches(Regex(#"[0-9a-f]{64}"#)))
}

/// フロントエンドの純粋写像(icons.ts)をbun testで検査する。
/// 生成先: tests/unit/oracles_generated.test.ts
class RendererGlyphs extends Clause {
  pattern = "renderer_glyphs"
  label = "example-tested"
  scenario: "glyph_known_values" | "planet_proxima_view"
}

/// 開発・検証toolingの実行時契約をbun testで検査する。
/// アプリ本体の挙動や外部OS UIの証明には使わない。
/// 生成先: tests/unit/oracles_generated.test.ts
class ToolingScenario extends Clause {
  pattern = "tooling_scenario"
  label = "example-tested"
  scenario: "e2e_targeted_cleanup" | "windows_portability"
}

/// Tauri IPCをmockしたWebKit renderer統合テスト(Playwright)。
/// Rust commandやOS通知を通った証明にはしない(docs/E2E.mdの線引き)。
/// 生成先: tests/renderer/oracles_generated.spec.ts、実行は just renderer-test
class RendererScenario extends Clause {
  pattern = "renderer_scenario"
  label = "example-tested"
  scenario: "palette_keyboard" | "delivery_flush" | "rule_row_controls" | "sidebar_fit" | "compact_table" | "expiry_cleanup" | "rule_naming" | "table_sort" | "unselected_picker_create" | "content_tabs" | "mute_window" | "locale_display" | "node_only" | "content_alerts" | "filter_auto_tab" | "content_picker" | "manual_reload"
}

/// 実アプリ(実IPC・実WKWebView)を通すWDIO Tauri E2E。renderer統合(RendererScenario)が
/// 担うDOM結線の再検証はせず、「本物のRust commandを往復する」ことの証明に絞る。
/// 生成先: tests/e2e/oracles_generated.e2e.ts、実行は just e2e
class E2eScenario extends Clause {
  pattern = "e2e_scenario"
  label = "example-tested"
  scenario: "palette_apply_ipc" | "delivery_error_surface" | "locale_config_roundtrip" | "manual_reload_ipc"
}

/// 機械検証しない残余。手動確認手順をSPEC.mdに列挙する
class Manual extends Clause {
  pattern = "manual"
  label = "manual"
  /// per-release: 毎リリース実施 / one-time: 一回限りの受入(対象が変わったときだけ再実施)
  cadence: "per-release" | "one-time" = "per-release"
  procedure: String
}
